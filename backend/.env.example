# CivicView backend — example env file.
# Copy to `.env` for local dev. In production (Render) these are set
# via the dashboard; do NOT commit a real .env to the repo.

# ─── External API keys ───────────────────────────────────────────────
# Congress.gov — required for live federal officials data. Free at:
#   https://api.congress.gov/sign-up/
CONGRESS_API_KEY=your_api_key_here

# Google Civic Information API — used by BallotTab for live polling-place
# + ballot data. App works without it (BallotTab shows the disabled
# state). Get a key at: https://console.cloud.google.com/apis/library
# GOOGLE_CIVIC_API_KEY=

# Anthropic Claude — powers the AI features (comment classification,
# post summaries, future bill explanations / "ask this rep" chat).
# App boots fine without this — AI affordances just hide and the
# /api/ai/health endpoint reports configured=false. Get a key from
# https://console.anthropic.com → API Keys. Billing is separate from
# the Claude.ai / Claude Code subscription pools — you'll need to add
# credits or auto-recharge on the console before requests go through.
# ANTHROPIC_API_KEY=

# Optional daily token caps enforced in app/services/ai_service.py.
# Defaults (60M input / 15M output) ≈ $135/day worst-case at Haiku rates.
# Set either to 0 to disable that dimension. Tighten if you're worried
# about abuse hitting an unexpected bill.
# AI_DAILY_INPUT_TOKEN_CAP=60000000
# AI_DAILY_OUTPUT_TOKEN_CAP=15000000

# ─── Moderation ───────────────────────────────────────────────────────
# When a post / comment / poll has been reported by N distinct users,
# it's auto-hidden (soft-deleted for posts and comments, archived with
# reason='reported' for polls) pending admin review. Reports still
# accumulate in *_reports tables either way. Set to 0 to disable
# auto-hide entirely (manual admin action only).
# REPORT_AUTO_HIDE_THRESHOLD=5

# Comma-separated email allowlist for /api/admin/* + the /admin page.
# Any rep or citizen account whose email matches gets admin powers.
# CITIZEN admins must also be verified=True (the seed flow below
# is the easiest path to a verified account today). Reps don't have
# a verified flag.
# Unset (or empty) → nobody is admin → every admin endpoint 403s.
# ADMIN_EMAILS=jeffreynuez1@gmail.com,civicview@civicview.app

# ─── Seeded citizen accounts (operator + demo) ────────────────────────
# JSON blob describing citizen accounts to seed on boot. Same shape
# as backend/demo_citizen_accounts.json. Use this to mint yourself
# an admin login (the .env file path) without waiting for ID.me.
# Set "verified": true to make the seeded account a non-demo / admin
# candidate. Idempotent on email — re-running just skips existing rows.
# DEMO_CITIZEN_ACCOUNTS_JSON={"citizens":[{"email":"civicview@civicview.app","password":"...","display_name":"CivicView Admin","city":"Internal","state":"FL","verified":true}]}

# ─── Notifications (Resend) ───────────────────────────────────────────
# When a new report comes in, fire an email to every address in
# ADMIN_EMAILS. Powered by Resend (resend.com). Unset RESEND_API_KEY
# disables notifications entirely — feature degrades silently to the
# in-app navbar badge.
#
# Get a key from https://resend.com (free tier: 3000 emails/month,
# 100/day). NOTIFICATION_FROM_EMAIL must be on a domain you've
# verified on Resend; for first-touch testing you can use
# `onboarding@resend.dev` which Resend allows without verification.
# RESEND_API_KEY=re_...
# NOTIFICATION_FROM_EMAIL=CivicView <noreply@civicview.app>

# Toggle without rotating the API key. Defaults to "true" when
# RESEND_API_KEY is set.
# REPORT_NOTIFICATIONS_ENABLED=true

# Used by the email body to build the "Open the queue" / "View page"
# links. Defaults to https://civicview.app.
# PUBLIC_APP_URL=https://civicview.app

# ─── Database ────────────────────────────────────────────────────────
# Local default is SQLite at backend/civiclens.db (zero-config).
# Production: paste the Render-provided Postgres URL. The legacy
# postgres:// scheme is auto-normalized to postgresql:// in db.py.
# DATABASE_URL=postgresql://user:pass@host:5432/civicview

# ─── Auth / sessions ─────────────────────────────────────────────────
# 32+ bytes of randomness. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Required in production. Local dev falls back to a hardcoded dev
# secret if unset, so you can boot without one.
# SESSION_SECRET=

# Cookie attributes:
#   COOKIE_SECURE=true     - required in production (HTTPS only).
#   COOKIE_SAMESITE=none   - required when frontend + backend live on
#                            different domains (Vercel + Render).
#                            Local dev (same-origin) keeps "lax".
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated. Local default covers localhost + 127.0.0.1 + the
# Tailscale IP for phone testing. Production: set to the Vercel URL(s).
# ALLOWED_ORIGINS=https://civicview.app,https://www.civicview.app
